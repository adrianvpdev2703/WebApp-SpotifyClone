<%- include('../partials/header', { title: 'Administrar Álbumes' }) %>

<main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-32">
  <div class="flex items-center mb-6 space-x-4">
    <a href="/admin" class="text-gray-400 hover:text-white transition">← Volver</a>
    <h2 class="text-2xl font-bold text-white">Administrar Álbumes</h2>
  </div>

  <div class="space-y-8">
    <form id="form-insert-album" enctype="multipart/form-data" class="bg-[#181818] p-6 rounded-lg border border-[#282828]">
      <h4 class="text-xl font-semibold text-white mb-4 border-b border-gray-700 pb-2">Crear Álbum</h4>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Nombre</label>
        <input type="text" name="nombre" required class="w-full bg-[#282828] border border-transparent rounded px-3 py-2 text-white focus:outline-none focus:ring-1 focus:ring-[#1db954] transition" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Artista</label>
        <select name="artista" required class="w-full bg-[#282828] border border-transparent rounded px-3 py-2 text-white focus:outline-none focus:ring-1 focus:ring-[#1db954] transition appearance-none">
          <option value="">Cargando artistas...</option>
        </select>
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Imagen</label>
        <input type="file" name="imagen" class="w-full bg-[#282828] text-gray-300 rounded px-3 py-2 file:mr-4 file:py-1 file:px-3 file:rounded file:border-0 file:bg-[#1db954] file:text-black hover:file:bg-green-600 transition" />
      </div>
      <button class="bg-[#1db954] hover:bg-green-600 text-black font-bold py-2 px-6 rounded-full transition">Crear</button>
    </form>

    <form id="form-put-album" enctype="multipart/form-data" class="bg-[#181818] p-6 rounded-lg border border-[#282828]">
      <h4 class="text-xl font-semibold text-white mb-4 border-b border-gray-700 pb-2">Actualizar Álbum (PUT)</h4>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">ID del Álbum</label>
        <input type="number" id="put-album-id" required class="w-full bg-[#282828] border border-transparent rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500 transition" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Nombre</label>
        <input type="text" name="nombre" required class="w-full bg-[#282828] border border-transparent rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500 transition" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Artista</label>
        <select name="artista" required class="w-full bg-[#282828] border border-transparent rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500 transition appearance-none">
          <option value="">Cargando artistas...</option>
        </select>
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Imagen</label>
        <input type="file" name="imagen" class="w-full bg-[#282828] text-gray-300 rounded px-3 py-2 file:mr-4 file:py-1 file:px-3 file:rounded file:border-0 file:bg-gray-600 file:text-white" />
      </div>
      <button class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded transition">Actualizar (PUT)</button>
    </form>

    <form id="form-patch-album" enctype="multipart/form-data" class="bg-[#181818] p-6 rounded-lg border border-[#282828]">
      <h4 class="text-xl font-semibold text-white mb-4 border-b border-gray-700 pb-2">Actualizar Álbum (PATCH)</h4>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">ID del Álbum</label>
        <input type="number" id="patch-album-id" required class="w-full bg-[#282828] rounded px-3 py-2 text-white focus:outline-none focus:border-yellow-500 transition" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Nombre</label>
        <input type="text" name="nombre" class="w-full bg-[#282828] rounded px-3 py-2 text-white focus:outline-none focus:border-yellow-500 transition" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Artista</label>
        <select name="artista" class="w-full bg-[#282828] rounded px-3 py-2 text-white focus:outline-none focus:border-yellow-500 transition appearance-none">
          <option value="">(Sin cambiar)</option>
        </select>
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Imagen</label>
        <input type="file" name="imagen" class="w-full bg-[#282828] text-gray-300 rounded px-3 py-2 file:mr-4 file:py-1 file:px-3 file:rounded file:border-0 file:bg-gray-600 file:text-white" />
      </div>
      <button class="bg-yellow-500 hover:bg-yellow-600 text-black font-bold py-2 px-6 rounded transition">Actualizar (PATCH)</button>
    </form>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <form id="form-delete-album" class="bg-[#181818] p-6 rounded-lg border border-red-900/30">
        <h4 class="text-xl font-semibold text-red-400 mb-4 border-b border-gray-700 pb-2">Eliminar Álbum</h4>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-400 mb-1">ID</label>
          <input type="number" id="delete-album-id" required class="w-full bg-[#282828] rounded px-3 py-2 text-white focus:outline-none focus:border-red-500 transition" />
        </div>
        <button class="bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-6 rounded transition w-full">Eliminar</button>
      </form>

      <form id="form-search-album" class="bg-[#181818] p-6 rounded-lg border border-[#282828]">
        <h4 class="text-xl font-semibold text-white mb-4 border-b border-gray-700 pb-2">Buscar Álbum</h4>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-400 mb-1">Nombre</label>
          <input type="text" name="nombre" class="w-full bg-[#282828] rounded px-3 py-2 text-white focus:outline-none focus:border-gray-400 transition" />
        </div>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-400 mb-1">Filtrar por Artista</label>
          <select name="artista" class="w-full bg-[#282828] rounded px-3 py-2 text-white focus:outline-none focus:border-gray-400 transition appearance-none">
            <option value="">Cualquiera</option>
          </select>
        </div>
        <button class="bg-gray-600 hover:bg-gray-500 text-white font-bold py-2 px-6 rounded transition w-full">Buscar</button>
      </form>
    </div>

    <div id="resultado" class="mt-8 bg-black text-green-400 font-mono p-4 rounded-lg overflow-x-auto text-sm border border-gray-800 min-h-[100px]"></div>
  </div>
</main>

<script>
  const resultado = document.getElementById("resultado");
  const showResult = async (res) => {
    try {
      const data = await res.json();
      resultado.innerText = JSON.stringify(data, null, 2);
    } catch {
      resultado.innerText = await res.text();
    }
  };

 // Cargar Artistas Dinámicamente
  document.addEventListener("DOMContentLoaded", async () => {
    try {
      // USAMOS GET /artistas en lugar del search
      const res = await fetch("/artistas");
      if (!res.ok) throw new Error("Error en la red al buscar artistas");

      const artistas = await res.json();
      let optionsHtml = `<option value="">Seleccione un artista...</option>`;
      artistas.forEach(a => optionsHtml += `<option value="${a.id}">${a.nombre} (ID: ${a.id})</option>`);

      document.querySelectorAll('select[name="artista"]').forEach(select => {
        const firstOption = select.querySelector('option');
        if(firstOption.value === "") {
          // Para el form de INSERT (requerido)
          select.innerHTML = `<option value="">${firstOption.textContent}</option>` + artistas.map(a => `<option value="${a.id}">${a.nombre}</option>`).join('');
        } else {
          // Para PATCH y SEARCH (opcional)
          select.innerHTML = optionsHtml;
        }
      });
    } catch (err) {
      console.error("Error cargando artistas", err);
      // Feedback visual si falla
      document.querySelectorAll('select[name="artista"]').forEach(select => {
        select.innerHTML = `<option value="">Error al cargar artistas</option>`;
      });
    }
  });

  document.getElementById("form-insert-album").addEventListener("submit", async (e) => {
    e.preventDefault();
    showResult(await fetch("/albumes", { method: "POST", body: new FormData(e.target) }));
  });

  document.getElementById("form-put-album").addEventListener("submit", async (e) => {
    e.preventDefault();
    const id = document.getElementById("put-album-id").value;
    const fd = new FormData(e.target); fd.delete("id");
    showResult(await fetch("/albumes/" + id, { method: "PUT", body: fd }));
  });

  document.getElementById("form-patch-album").addEventListener("submit", async (e) => {
    e.preventDefault();
    const id = document.getElementById("patch-album-id").value;
    const fd = new FormData(e.target); fd.delete("id");
    showResult(await fetch("/albumes/" + id, { method: "PATCH", body: fd }));
  });

  document.getElementById("form-delete-album").addEventListener("submit", async (e) => {
    e.preventDefault();
    showResult(await fetch("/albumes/" + document.getElementById("delete-album-id").value, { method: "DELETE" }));
  });

  document.getElementById("form-search-album").addEventListener("submit", async (e) => {
    e.preventDefault();
    const body = { nombre: e.target.nombre.value, artista: e.target.artista.value || undefined };
    showResult(await fetch("/albumes/search", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(body) }));
  });
</script>

<%- include('../partials/footer') %>

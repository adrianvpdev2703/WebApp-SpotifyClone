<%- include('../partials/header', { title: 'Administrar Géneros' }) %>

<main class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-32">
  <div class="flex items-center mb-6 space-x-4">
    <a href="/admin" class="text-gray-400 hover:text-white transition">← Volver</a>
    <h2 class="text-2xl font-bold text-white">Administrar Géneros</h2>
  </div>

  <div class="space-y-8">
    <form id="form-insert-genero" enctype="multipart/form-data" class="bg-[#181818] p-6 rounded-lg border border-[#282828]">
      <h4 class="text-xl font-semibold text-white mb-4 border-b border-gray-700 pb-2">Crear Género</h4>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Nombre</label>
        <input type="text" name="nombre" required class="w-full bg-[#282828] border border-transparent rounded px-3 py-2 text-white focus:outline-none focus:border-[#1db954] focus:ring-1 focus:ring-[#1db954] transition" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Imagen</label>
        <input type="file" name="imagen" class="w-full bg-[#282828] text-gray-300 border border-transparent rounded px-3 py-2 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-[#1db954] file:text-black hover:file:bg-green-600" />
      </div>
      <button class="bg-[#1db954] hover:bg-green-600 text-black font-bold py-2 px-6 rounded-full transition">Crear</button>
    </form>

    <form id="form-put-genero" enctype="multipart/form-data" class="bg-[#181818] p-6 rounded-lg border border-[#282828]">
      <h4 class="text-xl font-semibold text-white mb-4 border-b border-gray-700 pb-2">Actualizar Género (PUT)</h4>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">ID</label>
        <input type="number" name="id" required class="w-full bg-[#282828] border border-transparent rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500 transition" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Nombre</label>
        <input type="text" name="nombre" required class="w-full bg-[#282828] border border-transparent rounded px-3 py-2 text-white focus:outline-none focus:border-blue-500 transition" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Imagen</label>
        <input type="file" name="imagen" class="w-full bg-[#282828] text-gray-300 rounded px-3 py-2 file:mr-4 file:py-1 file:px-3 file:rounded file:border-0 file:bg-gray-600 file:text-white" />
      </div>
      <button class="bg-blue-600 hover:bg-blue-700 text-white font-bold py-2 px-6 rounded transition">Actualizar (PUT)</button>
    </form>

    <form id="form-patch-genero" enctype="multipart/form-data" class="bg-[#181818] p-6 rounded-lg border border-[#282828]">
      <h4 class="text-xl font-semibold text-white mb-4 border-b border-gray-700 pb-2">Actualizar Género (PATCH)</h4>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">ID</label>
        <input type="number" name="id" required class="w-full bg-[#282828] rounded px-3 py-2 text-white focus:outline-none focus:border-yellow-500 transition" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Nombre</label>
        <input type="text" name="nombre" class="w-full bg-[#282828] rounded px-3 py-2 text-white focus:outline-none focus:border-yellow-500 transition" />
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-400 mb-1">Imagen</label>
        <input type="file" name="imagen" class="w-full bg-[#282828] text-gray-300 rounded px-3 py-2 file:mr-4 file:py-1 file:px-3 file:rounded file:border-0 file:bg-gray-600 file:text-white" />
      </div>
      <button class="bg-yellow-500 hover:bg-yellow-600 text-black font-bold py-2 px-6 rounded transition">Actualizar (PATCH)</button>
    </form>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      <form id="form-delete-genero" class="bg-[#181818] p-6 rounded-lg border border-red-900/30">
        <h4 class="text-xl font-semibold text-red-400 mb-4 border-b border-gray-700 pb-2">Eliminar Género</h4>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-400 mb-1">ID</label>
          <input type="number" name="id" required class="w-full bg-[#282828] rounded px-3 py-2 text-white focus:outline-none focus:border-red-500 transition" />
        </div>
        <button class="bg-red-600 hover:bg-red-700 text-white font-bold py-2 px-6 rounded transition w-full">Eliminar</button>
      </form>

      <form id="form-search-genero" class="bg-[#181818] p-6 rounded-lg border border-[#282828]">
        <h4 class="text-xl font-semibold text-white mb-4 border-b border-gray-700 pb-2">Buscar Género</h4>
        <div class="mb-4">
          <label class="block text-sm font-medium text-gray-400 mb-1">Nombre</label>
          <input type="text" name="nombre" class="w-full bg-[#282828] rounded px-3 py-2 text-white focus:outline-none focus:border-gray-400 transition" />
        </div>
        <button class="bg-gray-600 hover:bg-gray-500 text-white font-bold py-2 px-6 rounded transition w-full">Buscar</button>
      </form>
    </div>

    <div id="resultado" class="mt-8 bg-black text-green-400 font-mono p-4 rounded-lg overflow-x-auto text-sm border border-gray-800 min-h-[100px]">
      </div>
  </div>
</main>

<script>
// ... (mismo código JS que ya tenías)
</script>

<%- include('../partials/footer') %>

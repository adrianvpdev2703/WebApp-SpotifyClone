<%- include('../partials/header', { title: 'Resultados de búsqueda' }) %>

<main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 pb-24">
  <div class="text-center mb-8">
    <h1 class="text-3xl font-bold text-white">Resultados para: "<%= query %>"</h1>
  </div>

  <div id="contenido" class="space-y-12"></div>
</main>

<script>
  const query = "<%= query %>";
  const contenidoDiv = document.getElementById("contenido");

  // Plantilla de la tarjeta adaptada a Tailwind
  const createCard = (title, img = "", extraHtml = "") => `
  <div>
    <div class="bg-[#181818] hover:bg-[#282828] transition-colors duration-300 rounded-lg p-4 h-full flex flex-col shadow-lg group">
      ${img ? `<div class="aspect-square w-full mb-4 overflow-hidden rounded-md shadow-[0_8px_24px_rgba(0,0,0,0.5)]"><img src="${img}" class="w-full h-full object-cover" alt="${title}"></div>` : `<div class="aspect-square w-full mb-4 bg-gray-700 rounded-md shadow-md"></div>`}
      <div class="flex-grow flex flex-col justify-between">
        <h5 class="text-white font-bold text-lg mb-2 truncate">${title}</h5>
        <div class="text-sm text-gray-400 space-y-3">
          ${extraHtml}
        </div>
      </div>
    </div>
  </div>
`;

  const buscarGlobal = async () => {
    contenidoDiv.innerHTML = "<p class='text-gray-400 text-center'>Buscando...</p>";

    const [resGeneros, resArtistas, resAlbumes, resCanciones] = await Promise.all([
      fetch("/generos/search", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ nombre: query }) }).then(r => r.json()),
      fetch("/artistas/search", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ nombre: query }) }).then(r => r.json()),
      fetch("/albumes/search", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ nombre: query }) }).then(r => r.json()),
      fetch("/canciones/search", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify({ nombre: query }) }).then(r => r.json()),
    ]);

    contenidoDiv.innerHTML = "";

    if (resGeneros.length) {
      contenidoDiv.innerHTML += `<div><h4 class="text-2xl font-bold text-white mb-4">Géneros</h4><div class='grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6'>` +
        resGeneros.map(g => createCard(g.nombre, g.imagen, `<button class="bg-[#1db954] hover:bg-green-600 text-black font-bold py-2 px-4 rounded-full w-full transition transform hover:scale-105" onclick="verArtistasGenero(${g.id})">Ver Artistas</button>`)).join("") + "</div></div>";
    }

    if (resArtistas.length) {
      contenidoDiv.innerHTML += `<div><h4 class="text-2xl font-bold text-white mb-4">Artistas</h4><div class='grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6'>` +
        resArtistas.map(a => createCard(a.nombre, a.imagen || "")).join("") + "</div></div>";
    }

    if (resAlbumes.length) {
      contenidoDiv.innerHTML += `<div><h4 class="text-2xl font-bold text-white mb-4">Álbumes</h4><div class='grid grid-cols-2 md:grid-cols-4 lg:grid-cols-5 gap-6'>` +
        resAlbumes.map(a => createCard(a.nombre, a.imagen || "", `<p class="truncate">Artista: ${a.artistaData?.nombre || ""}</p><button class="border border-gray-400 hover:border-white text-white py-1 px-4 rounded-full w-full transition mt-2" onclick="verCancionesAlbum(${a.id})">Ver Canciones</button><div id="album-canciones-${a.id}"></div>`)).join("") + "</div></div>";
    }

    if (resCanciones.length) {
      contenidoDiv.innerHTML += `<div><h4 class="text-2xl font-bold text-white mb-4">Canciones</h4><div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4'>` +
        resCanciones.map(c => `<div class="bg-[#181818] hover:bg-[#282828] p-3 rounded-md flex items-center space-x-4 transition">
            ${c.imagen ? `<img src="${c.imagen}" class="w-12 h-12 rounded" alt="${c.nombre}">` : `<div class="w-12 h-12 bg-gray-700 rounded"></div>`}
            <div class="flex-grow min-w-0">
                <p class="text-white font-semibold truncate">${c.nombre}</p>
                <p class="text-sm text-gray-400 truncate">${c.albumData?.nombre || ""}</p>
            </div>
            <audio controls src="${c.archivo}" class="w-1/2 h-8"></audio>
        </div>`).join("") + "</div></div>";
    }

    if (!resGeneros.length && !resArtistas.length && !resAlbumes.length && !resCanciones.length) {
      contenidoDiv.innerHTML = "<p class='text-gray-400 text-center mt-10'>No se encontraron resultados para tu búsqueda.</p>";
    }
  };

  buscarGlobal();
</script>

<%- include('../partials/footer') %>

<%- include('partials/header', { title: 'Inicio - Spotify Clone' }) %>

<main class="pb-24 pt-6">
  <h1 class="text-3xl font-bold text-white mb-6">Tu música favorita</h1>

  <div id="canciones-container" class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 mb-8">
    <p class="text-gray-400">Cargando música...</p>
  </div>
</main>

<script>
  // Cargar canciones al montar la vista
  async function cargarCanciones() {
    try {
      const res = await fetch('/canciones'); // Tu ruta GET existente
      const canciones = await res.json();
      const container = document.getElementById('canciones-container');
      container.innerHTML = '';

      canciones.forEach(c => {
        container.innerHTML += `
          <div class="bg-[#181818] hover:bg-[#282828] transition cursor-pointer rounded flex flex-col p-4 group">
            <div class="w-full aspect-square bg-gray-700 rounded mb-4 overflow-hidden">
               <img src="${c.imagen || ''}" class="w-full h-full object-cover">
            </div>
            <h3 class="text-white font-bold truncate">${c.nombre}</h3>
            <p class="text-gray-400 text-sm mb-4">${c.albumData?.nombre || 'Álbum desconocido'}</p>

            <audio controls class="w-full mt-auto" onended="handleSongEnded()">
                <source src="${c.archivo}" type="audio/mpeg">
            </audio>
          </div>
        `;
      });
    } catch (err) {
      console.error("Error cargando canciones:", err);
    }
  }

  // Esta función es llamada por el onended del tag <audio>
  function handleSongEnded() {
    // El evento global 'ended' en header.ejs lo detectará automáticamente
    console.log("Canción finalizada, enviando señal a Gamificación...");
  }

  document.addEventListener('DOMContentLoaded', cargarCanciones);
</script>

<%- include('partials/footer') %>

              "mode": "raw",
              "raw": "{\n    \"username\": \"Melomano\",\n    \"email\": \"musica@spotifyclone.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/usuarios/registro",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios", "registro"]
            }
          }
        },
        {
          "name": "Crear Usuario 4 (LinuxFan)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"LinuxFan\",\n    \"email\": \"tux@spotifyclone.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/usuarios/registro",

{
  "info": {
    "name": "Spotify Clone - Gamificación y Comunidades",
    "description": "Colección completa para probar el flujo de usuarios, rachas, rankings y comunidades.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Creación de Usuarios",
      "description": "Crea 5 usuarios para probar el sistema social.",
      "item": [
        {
          "name": "Crear Usuario 1 (AdrianTester)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"username\": \"AdrianTester\",\n    \"email\": \"adrian@spotifyclone.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/usuarios/registro",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios", "registro"]
            }
          }
        },
        {
          "name": "Crear Usuario 2 (GamerPro)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],

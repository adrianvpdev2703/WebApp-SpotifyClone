              "raw": "{\n    \"username\": \"GamerPro\",\n    \"email\": \"gamer@spotifyclone.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/usuarios/registro",
              "host": ["{{baseUrl}}"],
              "path": ["usuarios", "registro"]
            }
          }
        },
        {
          "name": "Crear Usuario 3 (Melomano)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
